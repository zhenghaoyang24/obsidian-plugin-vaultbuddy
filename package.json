{
  "name": "vaultbuddy",
  "version": "1.0.3",
  "description": "AI-powered chat assistant that stays in the sidebar. Supports streaming responses, chats with your entire vault as context, and provides answers grounded in your notes. Compatible with OpenAI-style APIs (DeepSeek, OpenAI, etc.).",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "ai",
    "chat",
    "knowledge-base",
    "vaultbuddy"
  ],
  "author": "zhenghaoyang24",
  "authorUrl": "https://github.com/zhenghaoyang24/",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhenghaoyang24/obsidian-plugin-vaultbuddy"
  },
  "homepage": "https://github.com/zhenghaoyang24/obsidian-plugin-vaultbuddy",
  "bugs": {
    "url": "https://github.com/zhenghaoyang24/obsidian-plugin-vaultbuddy/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "esbuild": "^0.19.11",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.3.3"
  },
  "dependencies": {
    "gpt-tokenizer": "^2.1.1",
    "marked": "^18.0.5"
  }
}
